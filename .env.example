DB_NAME=resource_tracker
DB_USER=admin
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# OpenStack Credentials
# For multiple sites, separate values with commas
# Example: site1_url,site2_url
OS_AUTH_URL=https://chi.tacc.chameleoncloud.org:5000/v3,https://kvm.tacc.chameleoncloud.org:5000/v3,https://chi.uc.chameleoncloud.org:5000/v3
OS_APPLICATION_CREDENTIAL_ID=id1,id2,id3
OS_APPLICATION_CREDENTIAL_SECRET=secret1,secret2,secret3

# Blazar Credentials (usually matches the corresponding OpenStack site)
BLAZAR_AUTH_URL=https://chi.tacc.chameleoncloud.org:5000/v3,https://kvm.tacc.chameleoncloud.org:5000/v3,https://chi.uc.chameleoncloud.org:5000/v3
BLAZAR_APPLICATION_CREDENTIAL_ID=id1,id2,id3
BLAZAR_APPLICATION_CREDENTIAL_SECRET=secret1,secret2,secret3
